{
  "name": "jayf0x-app",
  "version": "1.0.1",
  "private": false,
  "homepage": "https://jayf0x.github.io/",
  "scripts": {
    "dev": "vite --mode aaarch",
    "dev:prod": "vite",
    "dd": "rm -rf ./node_modules/.vite && vite",
    "build": "vite build --mode production",
    "preview": "vite preview",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "tailwind:fix:var": "find src -name \"*.tsx\" -o -name \"*.ts\" -o -name \"*.css\" | xargs perl -pi -e 's/\\\\b(\\\\w+)\\-\\(--\\\\1\\)/\\\\1-\\\\1/g'",
    "deploy": "bash scripts/deploy-site.sh",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "doctor": "npx react-doctor@latest"
  },
  "dependencies": {
    "@gradio/client": "^2.2.0",
    "@jayf0x/fluidity-js": "^1.2.2",
    "@million/lint": "^1.0.14",
    "@tanstack/query-sync-storage-persister": "^5.101.4",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-query-persist-client": "^5.101.4",
    "@tanstack/react-router": "^1.170.16",
    "@types/node": "^26.0.0",
    "axios": "^1.16.0",
    "framer-motion": "^12.38.0",
    "jotai": "^2.20.0",
    "lucide-react": "0.487.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-flip-cards": "^1.0.6",
    "react-icons": "^5.7.0",
    "react-router-dom": "^7.15.0",
    "react-type-animation": "^3.2.0",
    "react-xarrows": "^2.0.2",
    "three": "^0.184.0",
    "weighted-grid": "^1.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@webgpu/types": "^0.1.69",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "react-doctor": "^0.5.8",
    "react-scan": "^0.5.7",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.11"
  },
  "overrides": {
    "@hono/node-server": "2.0.5"
  }
